def map_frequency_to_score(freq_str):
    if not isinstance(freq_str, str):
        return 0
    s = freq_str.strip().lower()
    if 'obligate' in s: return 4
    if 'very frequent' in s: return 3
    if 'frequent' in s: return 2
    if 'occasional' in s: return 1
    if 'very rare' in s: return 0
    if 'rare' in s: return 0
    if 'excluded' in s: return 0
    match = re.match(r'(\d+)\s*/\s*(\d+)', s)
    if match:
        num, den = int(match.group(1)), int(match.group(2))
        if den > 0:
            ratio = num / den
            if ratio >= 0.8: return 3
            elif ratio >= 0.3: return 2
            elif ratio >= 0.05: return 1
            else: return 0
    logging.warning(f"Нестандартная частота: {freq_str}, -> 0")
    return 0

df_gene_pheno['Score'] = df_gene_pheno['Frequency'].apply(map_frequency_to_score)
gene_hpo_score = df_gene_pheno.groupby(['GeneSymbol', 'HPO_ID'])['Score'].max().reset_index()

