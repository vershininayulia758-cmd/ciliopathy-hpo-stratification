        mat = build_gene_term_matrix(ann_df, final_terms, agg_method=meth)
        # Используем линейные веса
        w = compute_weights_linear(mat)
        _, pleio = compute_axis_scores(mat, term_axis_map, w)
        pleio_agg[meth] = pleio

    pleio_agg_df = pd.DataFrame(pleio_agg)
    pleio_agg_df.index.name = 'gene_symbol'
    pleio_agg_df.to_csv(OUTPUT_DIR / 'sensitivity_aggregation.csv', encoding='utf-8-sig')
    # Корреляции
    corr_matrix = pleio_agg_df.corr(method='spearman')
    corr_matrix.to_csv(OUTPUT_DIR / 'sensitivity_aggregation_corr.csv', encoding='utf-8-sig')
    print("\n📊 Корреляции плеотропных индексов (Spearman):")
    print(corr_matrix.round(2))

    # 8. Интеграция CiliaMiner (опционально)
    cilia_file = "cilia_miner_classification.csv"  # Пользователь должен положить файл рядом
    if Path(cilia_file).exists():
        filtered_genes, cilia_df = apply_ciliaminer_filter(GENES, cilia_file)
        if len(filtered_genes) < len(GENES):
            # Повторяем анализ для отфильтрованного набора
            ann_filt = ann_df[ann_df['gene_symbol'].str.upper().isin([g.upper() for g in filtered_genes])]
            mat_filt = build_gene_term_matrix(ann_filt, final_terms, agg_method='max')
            w_filt = compute_weights_linear(mat_filt)
            axis_filt, pleio_filt = compute_axis_scores(mat_filt, term_axis_map, w_filt)
            mat_filt.to_csv(OUTPUT_DIR / 'gene_term_matrix_filtered.csv', encoding='utf-8-sig')
            axis_filt.to_csv(OUTPUT_DIR / 'axis_scores_filtered.csv', encoding='utf-8-sig')
            pleio_filt.to_csv(OUTPUT_DIR / 'pleiotropy_filtered.csv', encoding='utf-8-sig')
            print(f"✅ Анализ на отфильтрованных генах (n={len(filtered_genes)}) сохранён")
    else:
        print("ℹ️ Файл CiliaMiner не предоставлен, фильтрация не выполнена.")

    # 9. Аннотация ортологов (может занять время)
    try:
        ortho_df = annotate_orthologs(GENES, OUTPUT_DIR / 'ortholog_status.csv')
    except Exception as e:
        print(f"⚠️ Не удалось получить ортологов: {e}")

    print("\n" + "=" * 70)
    print("🎉 Анализ завершён! Все результаты в папке:", OUTPUT_DIR.resolve())
    print("=" * 70)

if __name__ == "__main__":
    main()
