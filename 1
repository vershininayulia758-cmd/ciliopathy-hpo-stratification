# 1. ЗАГРУЗКА hp.obo И ПОСТРОЕНИЕ ИЕРАРХИИ
# ============================================================
obo_path = "hp.obo"
download_file("http://purl.obolibrary.org/obo/hp.obo", obo_path)

def build_parents(obo_file):
    parents = defaultdict(list)
    current_id = None
    with open(obo_file, 'r', encoding='utf-8') as f:
        for line in f:
            line = line.strip()
            if line == '[Term]':
                current_id = None
            elif line.startswith('id: HP:'):
                current_id = line[4:].strip()
            elif line.startswith('is_a: HP:') and current_id:
                match = re.search(r'HP:\d+', line)
                if match:
                    parents[current_id].append(match.group())
    return parents

parents = build_parents(obo_path)
logging.info(f"Загружено {len(parents)} терминов с родительскими связями.")

def get_ancestors_cached(term, parents_dict, cache):
    if term in cache:
        return cache[term]
    ancestors = set()
    for p in parents_dict.get(term, []):
        ancestors.add(p)
        ancestors.update(get_ancestors_cached(p, parents_dict, cache))
    cache[term] = ancestors
    return ancestors

