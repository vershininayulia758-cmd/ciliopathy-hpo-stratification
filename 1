    gene = row['GeneSymbol']
    hpo = row['HPO_ID']
    score = row['Score']
    gene_hpo_dict[gene][hpo] = max(gene_hpo_dict[gene][hpo], score)

def compute_max_score_for_term(gene_annot, target_term):
    max_score = 0
    for annot_term, score in gene_annot.items():
        if annot_term == target_term:
            max_score = max(max_score, score)
        else:
            anc = ancestor_cache.get(annot_term, set())
            if target_term in anc:
                max_score = max(max_score, score)
    return max_score

