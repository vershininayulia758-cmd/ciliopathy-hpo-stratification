# ==================== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ====================

def download_file(url: str, dest: Path) -> None:
    """Скачивание файла с индикатором прогресса."""
    if dest.exists():
        print(f"📁 {dest.name} уже существует, пропускаем загрузку")
        return
    print(f"📥 Скачивание {dest.name}...")
    resp = requests.get(url, stream=True, timeout=60)
    resp.raise_for_status()
    total = int(resp.headers.get('content-length', 0))
    with open(dest, 'wb') as f, tqdm(total=total, unit='B', unit_scale=True, desc=dest.name) as bar:
        for chunk in resp.iter_content(chunk_size=8192):
            f.write(chunk)
            bar.update(len(chunk))
    print(f"✅ {dest.name} загружен")

# ==================== 1. HPO АННОТАЦИИ ====================

def load_hpo_annotations(filepath: Path, genes: List[str]) -> pd.DataFrame:
    """Чтение genes_to_phenotype.txt и фильтрация по генам."""
    print("📖 Чтение HPO аннотаций...")
    df = pd.read_csv(filepath, sep='\t', comment='#', dtype=str,
                     names=['gene_id','gene_symbol','HPO_ID','HPO_label','Frequency'])
    df = df[df['gene_symbol'].str.upper().isin([g.upper() for g in genes])].copy()
    df['Frequency'] = df['Frequency'].replace('', np.nan).replace('Not specified', np.nan)
    df.dropna(subset=['Frequency'], inplace=True)
    print(f"✅ Загружено {len(df)} записей для {df['gene_symbol'].nunique()} генов")
    return df

def freq_to_score(freq: str) -> Optional[int]:
    """Преобразование квалификатора HPO в целое число 0–4."""
    mapping = {
        'Obligate': 4,
        'Very frequent': 3,
        'Frequent': 2,
        'Occasional': 1,
        'Rare': 0,
        'Very rare': 0,
        'Excluded': 0
    }
    return mapping.get(freq, None)

def select_terms_hybrid(df: pd.DataFrame, expert_ids: Set[str], min_genes: int = 3) -> Set[str]:
    """Гибридный отбор HPO‑терминов."""
    term_counts = df.groupby('HPO_ID')['gene_symbol'].nunique()
    empirical_ids = set(term_counts[term_counts >= min_genes].index)
    final_ids = expert_ids.union(empirical_ids)
    print(f"   Экспертных: {len(expert_ids)}, эмпирических (≥{min_genes} генов): {len(empirical_ids)}, итого: {len(final_ids)}")
    return final_ids

# ==================== 2. МАТРИЦА ГЕН × ТЕРМИН ====================

def build_gene_term_matrix(df: pd.DataFrame, final_term_ids: Set[str],
                           agg_method: str = 'max') -> pd.DataFrame:
    """
    Создание матрицы ген × термин со значениями 0–4.
    agg_method: 'max', 'median', 'trimmed_mean', 'mode'.
    """
    df_filtered = df[df['HPO_ID'].isin(final_term_ids)].copy()
    df_filtered['score'] = df_filtered['Frequency'].apply(freq_to_score)
    df_filtered = df_filtered.dropna(subset=['score'])
    df_filtered['score'] = df_filtered['score'].astype(int)

    if agg_method == 'max':
        matrix = df_filtered.groupby(['gene_symbol', 'HPO_ID'])['score'].max().unstack()
    elif agg_method == 'median':
        matrix = df_filtered.groupby(['gene_symbol', 'HPO_ID'])['score'].median().unstack()
    elif agg_method == 'trimmed_mean':
        try:
            from scipy.stats import trim_mean
        except ImportError:
            raise ImportError("Для trimmed_mean необходим scipy. Установите: pip install scipy")
        def tm(x):
            return trim_mean(x, 0.1) if len(x) > 2 else np.mean(x)
        matrix = df_filtered.groupby(['gene_symbol', 'HPO_ID'])['score'].apply(tm).unstack()
    elif agg_method == 'mode':
        def mode_min(x):
            modes = x.mode()
            return modes.min() if not modes.empty else 0
        matrix = df_filtered.groupby(['gene_symbol', 'HPO_ID'])['score'].apply(mode_min).unstack()
    else:
        raise ValueError(f"Неизвестный agg_method: {agg_method}")

    # Приводим к единому индексу и столбцам
    all_genes = sorted(set(g.upper() for g in GENES))
    matrix = matrix.reindex(index=all_genes, columns=sorted(final_term_ids))
    matrix = matrix.fillna(np.nan)
    matrix.index.name = 'gene_symbol'
    matrix.columns.name = 'HPO_ID'
    return matrix

# ==================== 3. КЛИНИЧЕСКИЕ ОСИ ====================

def parse_ontology_ancestors(obo_path: Path, term_ids: Set[str]) -> Dict[str, Set[str]]:
    """Извлекает всех предков для заданных терминов по is_a отношениям."""
    print("🔗 Обработка hp.obo...")
    parents = {}
    current_id = None
    with open(obo_path, 'r') as f:
        for line in f:
            line = line.strip()
            if line.startswith('[Term]'):
                current_id = None
            elif line.startswith('id: HP:'):
                current_id = line[4:].strip()
            elif line.startswith('is_a: HP:'):
                if current_id is None:
                    continue
                parent_id = line.split('!')[0].split(':')[1].strip()
                full_parent = 'HP:' + parent_id
                parents.setdefault(current_id, []).append(full_parent)

    def get_ancestors(tid):
        stack = [tid]
        anc = set()
        while stack:
            cur = stack.pop()
            for p in parents.get(cur, []):
                if p not in anc:
                    anc.add(p)
                    stack.append(p)
        return anc

    ancestor_map = {}
    for tid in tqdm(term_ids, desc="Обход предков"):
        ancestor_map[tid] = get_ancestors(tid)
    return ancestor_map

def classify_terms_by_axes(term_ids: Set[str],
                           ancestor_map: Dict[str, Set[str]]) -> Dict[str, str]:
    """
    Распределение терминов по 10 осям согласно предкам.
    Приоритет: Laterality > Cardiac > Neuro_PosteriorFossa > Neuro_Cortical >
               Renal > Ocular > Hearing > Hepatic > Skeletal > Craniofacial > Endocrine_Metabolic.
    """
    axis_rules = {
        'Laterality': {'HP:0001696', 'HP:0000853', 'HP:0001651', 'HP:0004306', 'HP:0001650'},
        'Cardiac': {'HP:0001626'},
        'Neuro_PosteriorFossa': {'HP:0001317', 'HP:0012330'},  # cerebellum, hindbrain
        'Neuro_Cortical': {'HP:0000707'},   # nervous system
        'Renal': {'HP:0000077'},           # kidney
        'Ocular': {'HP:0000478'},          # eye
        'Hearing': {'HP:0000598', 'HP:0000365'},
        'Hepatic': {'HP:0001392', 'HP:0004297'},
        'Skeletal': {'HP:0000924'},        # skeletal system
        'Craniofacial': {'HP:0000152'},    # head or neck
        'Endocrine_Metabolic': {'HP:0000818', 'HP:0001939'},
    }
    priority = list(axis_rules.keys())

    term_axis = {}
    for tid in term_ids:
        anc = ancestor_map.get(tid, set())
        assigned = 'Other'
        for axis in priority:
            if anc.intersection(axis_rules[axis]):
                assigned = axis
                break
        term_axis[tid] = assigned
    return term_axis

# ==================== 4. ВЗВЕШИВАНИЕ ТЕРМИНОВ ====================

def compute_weights_linear(gene_term_matrix: pd.DataFrame) -> pd.Series:
    """Вес = 1 - частота (доля генов с баллом ≥1 среди не‑NaN)."""
    non_nan = gene_term_matrix.notna().sum()
    positive = (gene_term_matrix >= 1).sum()
    freq = positive / non_nan
    weights = 1.0 - freq
    weights[non_nan == 0] = 0.0
    return weights

def compute_weights_tfidf(gene_term_matrix: pd.DataFrame) -> pd.Series:
    """TF‑IDF вес = log(N / df_t), где df_t — число генов с баллом ≥1."""
    N = gene_term_matrix.shape[0]
    df_t = (gene_term_matrix >= 1).sum()
    # Защита от нуля
    df_t = df_t.replace(0, 1)
    weights = np.log(N / df_t)
    weights[df_t == 1] = 0.0
    return weights

# ==================== 5. АГРЕГАЦИЯ ПО ОСЯМ ====================

def compute_axis_scores(gene_term_matrix: pd.DataFrame,
                        term_axis_map: Dict[str, str],
                        term_weights: pd.Series) -> Tuple[pd.DataFrame, pd.Series]:
    """
    Рассчитывает средневзвешенный балл каждой оси и плеотропный индекс.
    Возвращает (axis_scores, pleiotropy_score).
    """
    axes = sorted(set(term_axis_map.values()) - {'Other'})
    axis_scores = pd.DataFrame(index=gene_term_matrix.index, columns=axes)

    for axis in axes:
        terms_in_axis = [t for t, a in term_axis_map.items() if a == axis and t in gene_term_matrix.columns]
        if not terms_in_axis:
            continue
        sub_mat = gene_term_matrix[terms_in_axis].astype(float)
        w = term_weights[terms_in_axis].values
        not_nan = sub_mat.notna()
        coverage = not_nan.sum(axis=1) / len(terms_in_axis)
        weighted_sum = (sub_mat.fillna(0) * w).sum(axis=1)
        weight_sum = (not_nan * w).sum(axis=1)
        with np.errstate(invalid='ignore'):
            avg = np.where(coverage >= 0.5, weighted_sum / weight_sum, np.nan)
        axis_scores[axis] = avg

    pleiotropy = axis_scores.sum(axis=1)
    return axis_scores, pleiotropy

# ==================== 6. ИНТЕГРАЦИЯ CILIAMINER ====================

def apply_ciliaminer_filter(genes: List[str],
                            cilia_file: Optional[str] = None) -> Tuple[List[str], pd.DataFrame]:
    """
    Если передан CSV с колонками Gene, Category, исключает Motile.
    Возвращает отфильтрованный список генов и датафрейм с категориями.
    """
    if cilia_file is None or not Path(cilia_file).exists():
        print("⚠️  Файл CiliaMiner не найден, пропускаем фильтрацию.")
        return genes, pd.DataFrame()

    cilia_df = pd.read_csv(cilia_file)
    if not {'Gene', 'Category'}.issubset(cilia_df.columns):
        print("⚠️  Файл CiliaMiner должен содержать 'Gene' и 'Category'. Пропускаем.")
        return genes, cilia_df

    # Приводим к верхнему регистру
    cilia_df['Gene'] = cilia_df['Gene'].str.upper()
    gene_cat = dict(zip(cilia_df['Gene'], cilia_df['Category']))

    # Исключаем Motile и неизвестные (Unknown) — можно только Motile
    filtered = []
    removed = []
    for g in genes:
        cat = gene_cat.get(g.upper(), 'Not in CiliaMiner')
        if cat in ['Motile']:   # только подвижные убираем, остальные оставляем
            removed.append(g)
        else:
            filtered.append(g)
    if removed:
        print(f"🚫 Исключено генов (Motile): {len(removed)}: {', '.join(removed)}")
    return filtered, cilia_df

# ==================== 7. ОРТОЛОГИ DANIO RERIO ====================

def get_ortholog_status(gene_symbol: str) -> Dict:
    """Запрос к Ensembl REST API для определения числа ортологов zebrafish."""
    url = (f"https://rest.ensembl.org/homology/symbol/human/{gene_symbol}"
           f"?content-type=application/json;type=orthologues;target_taxon=7955")
    try:
        resp = requests.get(url, timeout=15)
        if not resp.ok:
            return {'gene': gene_symbol, 'num_orthologs': 0, 'status': 'error'}
        data = resp.json()
        ortho_ids = set()
        for entry in data.get('data', []):
            for homo in entry.get('homologies', []):
                if homo['target']['species'] == 'danio_rerio':
                    ortho_ids.add(homo['target']['id'])
        num = len(ortho_ids)
        if num == 1:
            status = '1:1'
        elif num > 1:
            status = '1:many'
        else:
            status = 'none'
        return {'gene': gene_symbol, 'num_orthologs': num, 'status': status}
    except Exception as e:
        print(f"   ⚠️ Ошибка для {gene_symbol}: {e}")
        return {'gene': gene_symbol, 'num_orthologs': 0, 'status': 'error'}

def annotate_orthologs(genes: List[str], output_file: Path) -> pd.DataFrame:
    """Аннотирует все гены и сохраняет CSV."""
    print("🐟 Определение ортологов Danio rerio...")
    results = []
    for g in tqdm(genes, desc="Запросы к Ensembl"):
        results.append(get_ortholog_status(g))
    df = pd.DataFrame(results)
    df.to_csv(output_file, index=False, encoding='utf-8-sig')
    print(f"✅ Статус ортологов сохранён в {output_file}")
    return df

